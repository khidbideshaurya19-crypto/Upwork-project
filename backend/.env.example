PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# ---- Firebase ----
# Option A  (Development): place firebase-service-account.json at backend/firebase-service-account.json
#   Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
#
# Option B  (Production):  set the JSON as a single-line env var:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_ID",...}
